# BIRD2 iBGP configuration for bitcoin-ingress AnyCast
# Managed by Ansible — do not edit manually
# Role: upstream iBGP peer (same AS, advertises anycast prefix inward)

router id {{ bgp_router_id }};

protocol device {}

protocol direct {
  ipv4;
  ipv6;
}

protocol kernel {
  ipv4 {
    export all;
  };
  ipv6 {
    export all;
  };
}

{% if anycast_prefix | length > 0 %}
define ANYCAST4_PFXS = [ {{ anycast_prefix }} ];
filter export_anycast4 {
  if net ~ ANYCAST4_PFXS then accept;
  reject;
}

protocol static anycast4 {
  ipv4;
  route {{ anycast_prefix }} blackhole;
}
{% endif %}

{% if anycast_prefix6 | length > 0 %}
define ANYCAST6_PFXS = [ {{ anycast_prefix6 }} ];
filter export_anycast6 {
  if net ~ ANYCAST6_PFXS then accept;
  reject;
}

protocol static anycast6 {
  ipv6;
  route {{ anycast_prefix6 }} blackhole;
}
{% endif %}

filter accept_none { reject; }

{% for p in bgp_ibgp_peers %}
{% if p.peer_ip | default('') | length > 0 %}
protocol bgp ibgp_{{ loop.index0 }}_v4 {
  local as {{ bgp_local_as }};
  neighbor {{ p.peer_ip }} as {{ bgp_local_as }};
  hold time {{ bgp_hold_time }};
  keepalive time {{ bgp_keepalive }};
{% if bgp_password | length > 0 %}
  password "{{ bgp_password }}";
{% endif %}
  description "{{ p.description | default('ibgp-peer-' ~ loop.index0) }} (IPv4)";

  ipv4 {
    next hop self;
    import filter accept_none;
{% if anycast_prefix | length > 0 %}
    export filter export_anycast4;
{% else %}
    export filter accept_none;
{% endif %}
  };
}
{% endif %}
{% if p.peer_ip6 | default('') | length > 0 %}
protocol bgp ibgp_{{ loop.index0 }}_v6 {
  local as {{ bgp_local_as }};
  neighbor {{ p.peer_ip6 }} as {{ bgp_local_as }};
  hold time {{ bgp_hold_time }};
  keepalive time {{ bgp_keepalive }};
{% if bgp_password | length > 0 %}
  password "{{ bgp_password }}";
{% endif %}
  description "{{ p.description | default('ibgp-peer-' ~ loop.index0) }} (IPv6)";

  ipv6 {
    next hop self;
    import filter accept_none;
{% if anycast_prefix6 | length > 0 %}
    export filter export_anycast6;
{% else %}
    export filter accept_none;
{% endif %}
  };
}
{% endif %}
{% endfor %}
