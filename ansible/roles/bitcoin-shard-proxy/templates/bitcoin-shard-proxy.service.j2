[Unit]
Description=Bitcoin Shard Proxy
Documentation=https://github.com/lightwebinc/bitcoin-shard-proxy
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{ proxy_user }}
Group={{ proxy_group }}
EnvironmentFile=/etc/bitcoin-shard-proxy/config.env
ExecStartPre=/bin/sh -c '/sbin/ip -6 route add ff00::/8 dev {{ egress_iface if egress_iface is string else egress_iface[0] }} table local 2>/dev/null || true'
ExecStart={{ proxy_bin_dir }}/bitcoin-shard-proxy
Restart=on-failure
RestartSec=5
LimitNOFILE=65536

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths={{ proxy_install_dir }}
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
