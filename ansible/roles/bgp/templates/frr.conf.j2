! FRR configuration for bitcoin-ingress BGP — dual-stack
! Managed by Ansible — do not edit manually
! Ingress: dual-stack (IPv4 + IPv6)
! Fabric/egress: IPv6-only
!
frr defaults traditional
log syslog informational
!
router bgp {{ bgp_local_as }}
 bgp router-id {{ bgp_router_id }}
{% if bgp_peer_ip | length > 0 %}
 neighbor {{ bgp_peer_ip }} remote-as {{ bgp_peer_as }}
 neighbor {{ bgp_peer_ip }} timers {{ bgp_keepalive }} {{ bgp_hold_time }}
{% if bgp_password | length > 0 %}
 neighbor {{ bgp_peer_ip }} password {{ bgp_password }}
{% endif %}
{% endif %}
{% if bgp_peer_ip6 | length > 0 %}
 neighbor {{ bgp_peer_ip6 }} remote-as {{ bgp_peer_as }}
 neighbor {{ bgp_peer_ip6 }} timers {{ bgp_keepalive }} {{ bgp_hold_time }}
{% if bgp_password | length > 0 %}
 neighbor {{ bgp_peer_ip6 }} password {{ bgp_password }}
{% endif %}
{% endif %}
{% if bgp_peer_ip | length > 0 and bgp_prefix | length > 0 %}
 !
 address-family ipv4 unicast
  network {{ bgp_prefix }}
  neighbor {{ bgp_peer_ip }} route-map EXPORT4 out
  neighbor {{ bgp_peer_ip }} route-map DENY in
 exit-address-family
{% endif %}
{% if bgp_peer_ip6 | length > 0 and bgp_prefix6 | length > 0 %}
 !
 address-family ipv6 unicast
  network {{ bgp_prefix6 }}
  neighbor {{ bgp_peer_ip6 }} route-map EXPORT6 out
  neighbor {{ bgp_peer_ip6 }} route-map DENY in
 exit-address-family
{% endif %}
!
{% if bgp_prefix | length > 0 %}
ip prefix-list BGP4 seq 10 permit {{ bgp_prefix }}
!
route-map EXPORT4 permit 10
 match ip address prefix-list BGP4
!
{% endif %}
{% if bgp_prefix6 | length > 0 %}
ipv6 prefix-list BGP6 seq 10 permit {{ bgp_prefix6 }}
!
route-map EXPORT6 permit 10
 match ipv6 address prefix-list BGP6
!
{% endif %}
route-map DENY deny 10
!
