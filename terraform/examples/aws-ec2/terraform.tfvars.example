# Copy this file to terraform.tfvars and fill in your values.

aws_region     = "us-east-1"
name_prefix    = "bitcoin-ingress"
environment    = "production"

vpc_cidr            = "10.10.0.0/16"
availability_zones  = ["us-east-1a", "us-east-1b"]

instance_count = 2
instance_type  = "t3.medium"
key_name       = "my-ec2-keypair"
ssh_private_key = "~/.ssh/id_ed25519"

ssh_allowed_cidrs     = ["0.0.0.0/0"]
metrics_allowed_cidrs = ["0.0.0.0/0"]

allocate_eips = false

# Proxy
listen_port  = 9000
shard_bits   = 8
egress_mode  = "ethernet"
egress_iface = "eth1"

# GRE tunnel (set egress_mode = "gre" to use)
# gre_remote_ip = "198.51.100.1"

# BGP / AnyCast (set enable_bgp = true to use)
enable_bgp     = false
bgp_daemon     = "bird2"
anycast_prefix = ""
anycast_vip    = ""
bgp_local_as   = 65001
bgp_peer_as    = 65000
bgp_peer_ip    = ""
